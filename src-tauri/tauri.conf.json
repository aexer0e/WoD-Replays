{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WoD Replays",
  "version": "1.0.0",
  "identifier": "com.local.wod-replays",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WoD Replays",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
